{
  "name": "event-storage",
  "version": "1.0.0",
  "type": "module",
  "description": "An optimized embedded event store for node.js",
  "keywords": [
    "event-storage",
    "event-sourcing",
    "eventstore",
    "domain events",
    "embedded",
    "append-only",
    "cqrs",
    "log storage"
  ],
  "homepage": "https://github.com/albe/node-event-storage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albe/node-event-storage.git"
  },
  "bugs": {
    "url": "https://github.com/albe/node-event-storage/issues"
  },
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "test": "c8 --reporter=lcov --reporter=text mocha test/*.spec.js",
    "coverage": "c8 report --reporter=text-lcov | coveralls"
  },
  "files": [
    "src/Consumer*.js",
    "src/EventStore*.js",
    "src/EventStream*.js",
    "src/Index*.js",
    "src/IndexEntry*.js",
    "src/JoinEventStream*.js",
    "src/Partition*.js",
    "src/Storage*.js",
    "src/Watcher*.js",
    "src/Clock*.js",
    "src/Index/*.js",
    "src/Partition/*.js",
    "src/Storage/*.js",
    "src/WatchesFile.js",
    "src/util.js",
    "src/metadataUtil.js",
    "index.js"
  ],
  "license": "MIT",
  "maintainers": [
    {
      "name": "Alexander Berl",
      "email": "a.berl@outlook.com"
    }
  ],
  "engines": {
    "node": ">=18.0"
  },
  "dependencies": {
    "mkdirp": "^3.0.1"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "coveralls-next": "^6.0.1",
    "expect.js": "^0.3.1",
    "fs-extra": "^11.3.4",
    "mocha": "^11.7.5"
  }
}
